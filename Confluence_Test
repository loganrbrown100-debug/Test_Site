<div class="timer-widget" style="font-family:Arial,Helvetica,sans-serif; max-width:340px; margin:auto; border:2px solid #0069B0; padding:15px; text-align:center;">
  <div class="title" style="background:#f2f2f2; color:#0069B0; font-weight:bold; margin:-15px -15px 12px -15px; padding:8px 0;">
    Air Force Programs Inspection
  </div>
  <div class="boxes" style="display:flex; justify-content:space-between;">
    <div class="box" style="flex:1; margin:0 4px; background:#e9ecef; border-radius:4px; padding:8px 0;">
      <span class="value days" style="display:block; font-size:1.6rem; color:#212529;">00</span>
      <span class="label" style="font-size:0.85rem; color:#495057;">Days</span>
    </div>
    <div class="box" style="flex:1; margin:0 4px; background:#e9ecef; border-radius:4px; padding:8px 0;">
      <span class="value hours" style="display:block; font-size:1.6rem; color:#212529;">00</span>
      <span class="label" style="font-size:0.85rem; color:#495057;">Hours</span>
    </div>
    <div class="box" style="flex:1; margin:0 4px; background:#e9ecef; border-radius:4px; padding:8px 0;">
      <span class="value minutes" style="display:block; font-size:1.6rem; color:#212529;">00</span>
      <span class="label" style="font-size:0.85rem; color:#495057;">Minutes</span>
    </div>
    <div class="box" style="flex:1; margin:0 4px; background:#e9ecef; border-radius:4px; padding:8px 0;">
      <span class="value seconds" style="display:block; font-size:1.6rem; color:#212529;">00</span>
      <span class="label" style="font-size:0.85rem; color:#495057;">Seconds</span>
    </div>
  </div>
</div>

<script>
  // Target: 31 Aug 2026 12:00:00 EST (UTC‑5)
  const targetAF = new Date(Date.UTC(2026, 7, 31, 17, 0, 0)); // 17:00 UTC = 12:00 EST

  const daysAF    = document.querySelector('.timer-widget .days');
  const hoursAF   = document.querySelector('.timer-widget .hours');
  const minsAF    = document.querySelector('.timer-widget .minutes');
  const secsAF    = document.querySelector('.timer-widget .seconds');

  function updateAF() {
    const now = new Date();
    const diff = targetAF - now;
    if (diff <= 0) { daysAF.textContent = hoursAF.textContent = minsAF.textContent = secsAF.textContent = '00'; return; }

    const d = Math.floor(diff / 86400000);
    const h = Math.floor(diff / 3600000 % 24);
    const m = Math.floor(diff / 60000 % 60);
    const s = Math.floor(diff / 1000 % 60);

    daysAF.textContent    = String(d).padStart(2, '0');
    hoursAF.textContent   = String(h).padStart(2, '0');
    minsAF.textContent    = String(m).padStart(2, '0');
    secsAF.textContent    = String(s).padStart(2, '0');
  }
  updateAF();
  setInterval(updateAF, 1000);
</script>
